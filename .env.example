DEBUG=false
SECRET_KEY=change-me-use-a-long-random-secret
ALLOWED_HOSTS=auth.example.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://auth.example.com,http://localhost:8000
CORS_ALLOWED_ORIGINS=https://blog.example.com,https://store.example.com,https://social.example.com,http://localhost:3000
SESSION_COOKIE_DOMAIN=.example.com
DATABASE_URL=postgres://auth_user:auth_password@db:5432/auth_db
REDIS_URL=redis://redis:6379/0
ACCOUNT_EMAIL_DELIVERY=celery
FRONTEND_BASE_URL=https://accounts.example.com
EMAIL_VERIFICATION_URL=https://accounts.example.com/verify-email
PASSWORD_RESET_URL=https://accounts.example.com/reset-password
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=apikey-or-user
EMAIL_HOST_PASSWORD=secret
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@example.com
SERVER_EMAIL=server@example.com
SENTRY_DSN=

MFA_TOTP_ISSUER=Django Auth Platform

# v5 OAuth/OIDC-style provider settings
OIDC_ISSUER=https://auth.example.com
OIDC_AUTHORIZATION_CODE_LIFETIME_MINUTES=5

# v7 privacy/compliance operations
DATA_EXPORT_EXPIRY_DAYS=7
ACCOUNT_DELETION_CONFIRM_WINDOW_HOURS=24
ACCOUNT_DELETION_GRACE_DAYS=30

# v11 Stripe payment provider integration
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
BILLING_PROVIDER=stripe

# v18 operations/deployment maturity
APP_VERSION=40.0.0
OPERATIONS_PUBLIC_STATUS_ENABLED=true
BACKUP_STORAGE_BASE_URI=s3://replace-me/auth-platform-backups
MAINTENANCE_BYPASS_HEADER=X-Maintenance-Bypass

# v20 notification infrastructure
NOTIFICATION_DELIVERY_MODE=log

# v23 Fraud and abuse controls
FRAUD_ABUSE_ENFORCEMENT_MODE=manual

# v27 enterprise SSO readiness
ENTERPRISE_SSO_REQUIRE_SIGNED_ASSERTIONS=True
ENTERPRISE_SSO_ALLOW_IDP_INITIATED_LOGIN=False

# v32 tax/pricing controls
TAX_PRICING_DEFAULT_SOURCE=manual
TAX_PRICING_ENABLE_PROVIDER_REFRESH=false

# v33 completion/stabilization controls
PLATFORM_FEATURE_COMPLETION_MODE=stabilize
# Comma-separated Django apps considered production-MVP critical.
PRODUCTION_MVP_APPS=accounts,billing,security_ops,ops,admin_console,customer_portal,notifications,observability
# Comma-separated advanced apps kept available but hardened gradually.
ADVANCED_APPS=compliance,data_governance,fraud_abuse,identity_hardening,enterprise_sso,scim_provisioning,oidc_provider,sdk_registry,usage_billing,tax_pricing,developer_platform

# v39 admin-control service-to-service signing
ADMIN_INTEGRATION_MAX_CLOCK_SKEW_SECONDS=300

# v40 production boot validation
PRODUCTION_BOOT_VALIDATION_REQUIRED=true
PRODUCTION_BOOT_EXPECTED_HOSTS=auth.example.com,billing.example.com,api.example.com
PRODUCTION_BOOT_EXPECTED_ORIGINS=https://admin.yourdomain.com,https://admin-api.yourdomain.com
PRODUCTION_BOOT_STRICT_OPTIONALS=false

# v43 business-focused runtime profile
AUTH_PAYMENT_PROFILE=business
AUTH_PAYMENT_ENABLE_ADVANCED_APPS=false
BUSINESS_PRODUCT_CODES=zatca,typing,chat,blog
ADMIN_CONTROL_SERVICE_NAME=admin-control-platform
ADMIN_CONTROL_ORIGINS=https://admin.yourdomain.com,https://admin-api.yourdomain.com

# v44 business rules: product access checks for ZATCA, typing, chat, and blog.
# Keep enabled for this business-focused core.
BUSINESS_RULES_ENABLED=true
